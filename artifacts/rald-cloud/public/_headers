# Cloudflare Pages — security + cache headers for app.rald.cloud

# Hashed JS/CSS/font assets — 1 year immutable (hash in filename guarantees freshness)
/assets/*
  Cache-Control: public, max-age=31536000, immutable
  X-Content-Type-Options: nosniff
  Vary: Accept-Encoding

# Static assets — moderate cache
/rald-logo.png
  Cache-Control: public, max-age=86400, must-revalidate
/opengraph.jpg
  Cache-Control: public, max-age=86400, must-revalidate
/robots.txt
  Cache-Control: public, max-age=86400
/sitemap.xml
  Cache-Control: public, max-age=3600, must-revalidate

# HTML shell — always revalidate, full security policy
/*.html
  Cache-Control: public, max-age=0, must-revalidate
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), camera=(), microphone=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https:; connect-src 'self' https://api.rald.cloud https://auth.rald.cloud https://*.supabase.co https://*.replit.dev https://*.replit.app https://*.pages.dev; frame-ancestors 'none'

# Root — same security policy as HTML shell
/
  Cache-Control: public, max-age=0, must-revalidate
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), camera=(), microphone=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https:; connect-src 'self' https://api.rald.cloud https://auth.rald.cloud https://*.supabase.co https://*.replit.dev https://*.replit.app https://*.pages.dev; frame-ancestors 'none'
